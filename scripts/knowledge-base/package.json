{
  "name": "teams-for-linux-knowledge-base",
  "version": "1.0.0",
  "description": "Knowledge base generation scripts for Teams for Linux project",
  "main": "index.js",
  "scripts": {
    "extract": "node extract-issues.js",
    "extract:help": "node extract-issues.js --help",
    "analyze": "node analyze-issues.js",
    "generate": "node generate-knowledge-base.js",
    "build": "npm run extract && npm run analyze && npm run generate",
    "test": "node extract-issues.js --help",
    "lint": "eslint *.js"
  },
  "dependencies": {},
  "devDependencies": {
    "eslint": "^8.0.0"
  },
  "keywords": [
    "teams-for-linux",
    "knowledge-base",
    "github-issues",
    "nlp",
    "automation"
  ],
  "author": "Teams for Linux Contributors",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  }
}
